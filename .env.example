# ── HelloAsso ────────────────────────────────────────────────────────────────
# Obtenir sur : https://dev.helloasso.com → Mon organisation → API
HELLOASSO_CLIENT_ID=votre_client_id
HELLOASSO_CLIENT_SECRET=votre_client_secret
# Slug de l'organisation visible dans l'URL HelloAsso
# ex : https://www.helloasso.com/associations/gan-israel-beth-hillel → "gan-israel-beth-hillel"
HELLOASSO_ORG_SLUG=gan-israel-beth-hillel

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# Activer l'authentification 2FA puis créer un "Mot de passe d'application" Gmail
SMTP_USER=votre.adresse@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=choisir_un_mot_de_passe_fort

# ── URL publique (Railway / hébergement) ──────────────────────────────────────
# URL complète de votre site en production (sans slash final)
# Utilisée pour les redirections HelloAsso et les liens dans les emails
VITE_PUBLIC_URL=https://votre-app.railway.app

# ── Google Sheets (optionnel) ─────────────────────────────────────────────────
# URL du webhook Google Apps Script pour synchroniser les inscriptions
# Laisser vide si non utilisé
SHEETS_WEBHOOK=

# ── Formspree (optionnel) ─────────────────────────────────────────────────────
# ID du formulaire Formspree pour sauvegarde supplémentaire
# Laisser vide si non utilisé
VITE_FORMSPREE_ID=

# ── Mode test ─────────────────────────────────────────────────────────────────
# true = skip l'appel HelloAsso réel (utile en développement)
TEST_MODE=false
